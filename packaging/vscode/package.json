{
  "name": "vaults-diagram-tools-vscode",
  "displayName": "Vaults Diagram Tools",
  "description": "Mermaid to assets. Source code to maps. MCP for agents.",
  "icon": "icon.png",
  "version": "0.1.3",
  "publisher": "malnati",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "vaultsDiagramTools.renderCurrentMermaid",
        "title": "Vaults Diagram Tools: Render Current Mermaid File"
      }
    ],
    "configuration": {
      "title": "Vaults Diagram Tools",
      "properties": {
        "vaultsDiagramTools.cliPath": {
          "type": "string",
          "default": "vaults-mermaid-render",
          "description": "Path to vaults-mermaid-render CLI."
        }
      }
    }
  }
}
